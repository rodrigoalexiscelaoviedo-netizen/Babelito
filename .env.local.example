# Copiá este archivo a .env.local y completá con tus valores.
# NUNCA commitees .env.local (ya está en .gitignore).

# URL del proyecto Supabase (ej: https://xxxx.supabase.co)
VITE_SUPABASE_URL=

# Anon / publishable key de Supabase. Es la ÚNICA key que puede vivir
# cerca del frontend, y solo porque RLS protege las tablas.
VITE_SUPABASE_ANON_KEY=

# NOTA: la API key de Anthropic NO va acá. Vive como secret de la
# Edge Function (supabase secrets set ANTHROPIC_API_KEY=...).
# La service_role key de Supabase TAMPOCO va acá ni en el front.
